{
  "name": "monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "typecheck:watch": "turbo watch typecheck",
    "test": "turbo test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm turbo boundaries && pnpm exec spectral lint apps/api/openapi/v1.json --ruleset apps/api/.spectral.yaml",
    "knip": "knip",
    "check:brand-placeholders": "node scripts/check-brand-placeholders.mjs",
    "check:client-secrets": "node scripts/check-client-secrets.mjs",
    "check:pr-title": "node scripts/check-pr-title.mjs",
    "gen:all": "tsx scripts/gen-all.ts",
    "prepare": "lefthook install --force || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@faker-js/faker": "^10.4.0",
    "@stoplight/spectral-cli": "^6.15.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.4.0",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.8.0",
    "supertest": "^7.1.0",
    "testcontainers": "^12.0.0",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24"
  }
}
