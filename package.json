{
  "name": "monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "typecheck:watch": "turbo watch typecheck",
    "test": "turbo test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm turbo boundaries && pnpm exec spectral lint apps/api/openapi/v1.json --ruleset apps/api/.spectral.yaml",
    "preflight": "git fetch -q origin main; TURBO_SCM_BASE=origin/main turbo run typecheck lint --affected && pnpm turbo boundaries && node scripts/check-docs.mjs && node scripts/governance/check-changelog-fragment.mjs --base origin/main --head HEAD --title \"$(git log -1 --format=%s)\"",
    "preflight:full": "git fetch -q origin main; TURBO_SCM_BASE=origin/main turbo run typecheck lint test --affected && pnpm turbo boundaries && node scripts/check-docs.mjs && node scripts/governance/check-changelog-fragment.mjs --base origin/main --head HEAD --title \"$(git log -1 --format=%s)\"",
    "knip": "knip",
    "codegraph:ensure": "node scripts/codegraph.mjs ensure",
    "codegraph:init": "node scripts/codegraph.mjs init",
    "codegraph:ready": "node scripts/codegraph.mjs ready",
    "codegraph:status": "node scripts/codegraph.mjs status",
    "codegraph:sync": "node scripts/codegraph.mjs sync",
    "check:brand-placeholders": "node scripts/check-brand-placeholders.mjs",
    "check:client-secrets": "node scripts/check-client-secrets.mjs",
    "check:archetype-body": "node scripts/governance/check-archetype-body.mjs",
    "check:changelog": "node scripts/governance/check-changelog-fragment.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "check:nav": "tsx scripts/check-nav.ts",
    "check:sitemap": "tsx scripts/check-sitemap.ts",
    "check:structure": "tsx scripts/gen-structure.ts --check",
    "check:shadcn-upstream": "pnpm --filter @workspace/ui check:shadcn-upstream",
    "review:shadcn-upstream": "pnpm --filter @workspace/ui review:shadcn-upstream",
    "check:pr-title": "node scripts/check-pr-title.mjs",
    "changelog:add": "node scripts/governance/add-changelog-entry.mjs",
    "changelog:preview": "node scripts/governance/collect-changelog.mjs --dry-run",
    "changelog:collect": "node scripts/governance/collect-changelog.mjs",
    "gen:structure": "tsx scripts/gen-structure.ts",
    "gen:all": "tsx scripts/gen-all.ts",
    "prepare": "lefthook install --force || true"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "1.4.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@stoplight/spectral-cli": "^6.16.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.5",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.13.0",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  }
}
