              <xs:element maxOccurs="1" minOccurs="0" name="VetaNP">
                <xs:complexType>
                  <xs:attribute name="c_nest_uctu" use="optional">
                    <xs:annotation>
                      <xs:documentation>Uveďte číslo zahraničního účtu (nebo účtu v ČR vedeného v cizí měně) ve formátu IBAN.&lt;br&gt;&lt;br&gt;Položka obsahuje kritickou kontrolu: při žádosti o vrácení přeplatku na zahraniční účet nebo účet vedený v cizí měně musí být vyplněno číslo zahraničního účtu.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:minLength value="0"/>
                        <xs:maxLength value="34"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:attribute>
                  <xs:attribute name="zp_vrac" use="optional">
                    <xs:annotation>
                      <xs:documentation>Způsob vrácení přeplatku:&lt;br&gt;&lt;b&gt;U&lt;/b&gt; - na účet&lt;br&gt;&lt;b&gt;Z&lt;/b&gt; - na zahraniční účet.&lt;br&gt;&lt;br&gt;Položka obsahuje kritické kontroly: pro způsob U  musí být vyplněny všechny relevantní položky bankovního spojení.&#13;
</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:minLength value="0"/>
                        <xs:maxLength value="1"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:attribute>
                  <xs:attribute name="k_meny_uctu" use="optional">
                    <xs:annotation>
                      <xs:documentation>Uveďte kód měny, ve které je zahraniční účet (nebo účet v ČR vedený v cizí měně) veden.&lt;br&gt;&lt;br&gt;Položka obsahuje kritickou kontrolu: hodnota musí být platnou hodnotou z číselníku měn.&lt;br&gt;&lt;br&gt;Pro hodnotu této položky použijte číselník Měna (zeme). Z číselníku se vkládá položka k_meny.&lt;br&gt;
Pro popis číselníku Měna klikněte &lt;a href="https://mojedane.gov.cz/pmd/dokumentace/ciselniky/ukazka/mena"&gt;zde&lt;/a&gt;.</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
                        <xs:minLength value="0"/>
                        <xs:maxLength value="3"/>
