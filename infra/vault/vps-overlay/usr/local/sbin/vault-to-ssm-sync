#!/usr/bin/env bash
# Vault → AWS SSM SecureString sync (AFF-245 M4).
#
# Mirrors the app secrets from Vault (per env) into SSM SecureString — the
# runtime cache ECS reads at task start. Runs every 5 min via
# /etc/systemd/system/vault-to-ssm-sync.timer.
#
# Synced keys (Vault path → SSM parameter), per env {staging,production}:
#   platform/${env}/better-auth-secret    → /monorepo/${env}/better-auth-secret
#   platform/${env}/resend-api-key        → /monorepo/${env}/resend-api-key
#   platform/${env}/notify-shared-secret  → /monorepo/${env}/notify-shared-secret
#
# (`vault kv get` is KV-v2-aware: it auto-translates `platform/${k}` to the
# API path `platform/data/${k}`. Passing `data/` explicitly would double it.)
#
# CLOUDFLARE_TUNNEL_TOKEN intentionally NOT synced through Vault per
# plan locked decision #9 (chicken-and-egg — tunnel must be up before
# Vault is reachable). It flows direct from the GH repo secret to SSM
# via a step in _deploy-aws.yml.
#
# Change detection (zero KMS in steady state):
#   Per-key state lives LOCALLY in ${STATE_DIR} (systemd StateDirectory,
#   root-only): line 1 = sha256 of the last-synced plaintext, line 2 = the
#   SSM parameter Version our own PutParameter returned.
#     - Vault-side change: sha256(Vault value) != stored hash → rewrite.
#     - SSM-side tamper:   GetParameter WITHOUT --with-decryption returns
#       only metadata + ciphertext (no kms:Decrypt). A Version different
#       from the stored one means an out-of-band write → heal from Vault
#       (source of truth) within one 5-min cycle.
#   An unchanged secret therefore costs zero KMS requests. The previous
#   decrypt-and-compare design burned ~17k KMS requests / 10 days (85% of
#   the 20k/mo Free Tier) on idle polling; KMS (kms:Encrypt via the
#   aws/ssm key) is now paid only on a real write. Nothing derived from a
#   secret value (hash or otherwise) is ever stored in AWS — sha256 of a
#   structured secret in a plaintext parameter would be an offline
#   brute-force target.
#
# Liveness (two consumers, both must stay in sync with this script):
#   1. /monorepo/${env}/sync-heartbeat — epoch seconds, type String (NOT
#      SecureString: the value is not secret and String costs no KMS).
#      Read by .github/workflows/secrets-drift.yml (daily, fails if > 15
#      min stale) and the post-deploy verify in _deploy-aws.yml.
#   2. CloudWatch Monorepo/VaultSync SyncSuccess{Env=${env}} = 1 — feeds
#      the monorepo-${env}-vault-ssm-sync-stale alarm (observability
#      stack), which pages within 15 min if this loop dies.
#   Both are written only after a CLEAN pass for the env, and never when
#   Vault is unreachable (the preflight below exits 1 first), so a dead or
#   half-dead sync trips the alarm instead of being masked.
#
# Exit codes:
#   0  — all keys synced (or already in sync), heartbeat + liveness emitted
#   1  — required env var missing OR Vault unreachable / token invalid
#   2  — at least one SSM write or liveness emit failed; sentinel file is
#         created (heartbeat + metric withheld for the failed env so the
#         staleness alarm + drift workflow trip)
#
# Tracks: AFF-245 M4. Plan: docs/plans/SECRETS-MIGRATION.md § M4 task 2.

set -euo pipefail

# --- config + creds ------------------------------------------------------

CONFIG_FILE=/root/.config/vault-to-ssm/.env
if [[ ! -r "$CONFIG_FILE" ]]; then
  echo "[vault-to-ssm] missing $CONFIG_FILE (mode 0600); aborting" >&2
  exit 1
fi
set -a
# shellcheck disable=SC1090
source "$CONFIG_FILE"
set +a

REQUIRED_VARS=(
  VAULT_ADDR
  VAULT_TOKEN
  AWS_REGION
  # The script can rely on the AWS CLI default credential chain if running
  # on an EC2/ECS host, but the VPS isn't AWS-hosted, so explicit env vars
  # are required here. They differ from the unseal user — this user only
  # needs ssm:PutParameter/GetParameter on the synced params, kms:Encrypt +
  # kms:GenerateDataKey via the default aws/ssm key (no kms:Decrypt — this
  # script never reads a SecureString back), and cloudwatch:PutMetricData
  # on the Monorepo/VaultSync namespace.
  AWS_ACCESS_KEY_ID
  AWS_SECRET_ACCESS_KEY
)
for v in "${REQUIRED_VARS[@]}"; do
  if [[ -z "${!v:-}" ]]; then
    echo "[vault-to-ssm] required env var $v is empty; aborting" >&2
    exit 1
  fi
done

# Local change-detection state. systemd injects $STATE_DIRECTORY when the
# unit declares StateDirectory=vault-to-ssm; the fallback covers manual
# root runs. Files hold a secret-derived hash → keep them root-only.
STATE_DIR="${STATE_DIRECTORY:-/var/lib/vault-to-ssm}"
mkdir -p "$STATE_DIR"
umask 077

SENTINEL=/var/run/vault-to-ssm-sync.failed
rm -f "$SENTINEL"

# --- Vault preflight ------------------------------------------------------
#
# `vault kv get` failures inside sync_one are treated as "key not seeded
# yet" and skipped. Without this preflight, a sealed Vault / expired token
# would skip ALL keys, count every env as clean, and emit liveness — the
# exact failure the staleness alarm exists to catch would be masked.
if ! vault token lookup >/dev/null 2>&1; then
  echo "[vault-to-ssm] Vault unreachable or token invalid (vault token lookup failed); aborting" >&2
  exit 1
fi

# --- helper: vault GET, hash+version compare, SSM PUT on change ----------

# Args: $1 env (staging|production), $2 key
# Returns non-zero if an SSM write failed (caller maps to exit 2).
sync_one() {
  local env="$1"
  local key="$2"
  local vault_path="platform/${env}/${key}"
  local ssm_name="/monorepo/${env}/${key}"
  local state_file="${STATE_DIR}/${env}--${key}"

  echo "[vault-to-ssm] ${vault_path} → ${ssm_name}"

  # `vault kv get -field=value` exits 2 if the key is missing — guard.
  # (Vault reachability/auth is established by the preflight above, so a
  # failure here means the key genuinely isn't seeded.)
  local vault_val
  if ! vault_val=$(vault kv get -field=value "$vault_path" 2>/dev/null); then
    echo "[vault-to-ssm] WARN: ${vault_path} not present in Vault (skipping)" >&2
    return 0
  fi
  if [[ -z "$vault_val" ]]; then
    echo "[vault-to-ssm] WARN: ${vault_path} is empty in Vault (skipping)" >&2
    return 0
  fi

  local vault_hash stored_hash="" stored_version=""
  vault_hash=$(printf '%s' "$vault_val" | sha256sum | cut -d' ' -f1)
  if [[ -r "$state_file" ]]; then
    stored_hash=$(sed -n '1p' "$state_file")
    stored_version=$(sed -n '2p' "$state_file")
  fi

  local reason
  if [[ "$vault_hash" != "$stored_hash" ]]; then
    reason="vault value changed (or first sync)"
  else
    # Plaintext unchanged — verify nobody rewrote the SSM param out-of-band.
    # No --with-decryption → metadata only, no KMS request.
    local current_version
    current_version=$(aws ssm get-parameter \
      --name "$ssm_name" \
      --region "$AWS_REGION" \
      --query 'Parameter.Version' --output text 2>/dev/null || echo "__MISSING__")
    if [[ "$current_version" == "$stored_version" ]]; then
      echo "[vault-to-ssm]   in sync (hash + version match); no write"
      return 0
    fi
    reason="SSM version drift (expected ${stored_version}, found ${current_version}); healing from Vault"
  fi

  # Write the SecureString (1 kms:Encrypt via aws/ssm) and capture the new
  # Version from the PutParameter response — no read-back needed. Value is
  # piped via stdin to keep the secret off the process arglist.
  local new_version
  if ! new_version=$(printf '%s' "$vault_val" | aws ssm put-parameter \
    --name "$ssm_name" \
    --type SecureString \
    --overwrite \
    --region "$AWS_REGION" \
    --value file:///dev/stdin \
    --query 'Version' --output text); then
    echo "[vault-to-ssm]   ERROR: SecureString write failed for ${ssm_name}" >&2
    return 1
  fi
  # State is written AFTER the successful SSM write: a crash in between
  # leaves stale state, so the next run re-detects and retries — never the
  # reverse (state claiming "synced" while SSM is stale).
  printf '%s\n%s\n' "$vault_hash" "$new_version" > "$state_file"
  echo "[vault-to-ssm]   wrote v${new_version} (${reason})"
}

# --- liveness: SSM heartbeat (workflows) + CW metric (alarm) -------------

# Epoch-seconds heartbeat consumed by secrets-drift.yml and the post-deploy
# verify in _deploy-aws.yml. Type String: the timestamp is not a secret,
# and String writes cost no KMS (the old SecureString heartbeat was 2
# guaranteed KMS Encrypts per run for no security benefit).
write_heartbeat() {
  local env="$1"
  local now
  now=$(date -u +%s)
  aws ssm put-parameter \
    --name "/monorepo/${env}/sync-heartbeat" \
    --type String \
    --overwrite \
    --region "$AWS_REGION" \
    --value "$now" >/dev/null
}

# One datapoint per clean env pass; the monorepo-${env}-vault-ssm-sync-stale
# alarm fires when none arrives for 15 min. PutMetricData is scoped by IAM
# to the Monorepo/VaultSync namespace.
emit_sync_metric() {
  local env="$1"
  aws cloudwatch put-metric-data \
    --namespace "Monorepo/VaultSync" \
    --metric-name "SyncSuccess" \
    --dimensions "Env=${env}" \
    --value 1 \
    --region "$AWS_REGION" >/dev/null
}

# --- main loop -----------------------------------------------------------

FAILED=0

for env in staging production; do
  env_ok=1
  for key in better-auth-secret resend-api-key notify-shared-secret; do
    if ! sync_one "$env" "$key"; then
      FAILED=1
      env_ok=0
    fi
  done
  # Heartbeat + metric only on a clean pass: a partial failure must trip
  # the staleness alarm and the drift workflow, not be masked by them.
  if [[ "$env_ok" == "1" ]]; then
    if ! write_heartbeat "$env"; then
      echo "[vault-to-ssm] WARN: heartbeat write failed for $env" >&2
      FAILED=1
    fi
    if ! emit_sync_metric "$env"; then
      echo "[vault-to-ssm] WARN: liveness metric emit failed for $env" >&2
      FAILED=1
    fi
  fi
done

if [[ "$FAILED" == "1" ]]; then
  touch "$SENTINEL"
  echo "[vault-to-ssm] DONE WITH FAILURES"
  exit 2
fi

echo "[vault-to-ssm] DONE OK"
