# Dependencies
node_modules

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Pagefind index — generated by `pnpm --filter docs build:pagefind` post-build.
# Each deploy regenerates the static asset; never source-controlled.
apps/docs/public/_pagefind/

# Build Outputs
.next/
out/
build
dist

# TypeScript
*.tsbuildinfo

# Debug
*.log

# Storybook
storybook-static

# Agent cleanup artifacts (never deleted per project rules, kept locally)
_junk/

# Claude Code agent worktrees (ephemeral, local only). Project-level
# skills under `.claude/skills/` ARE versioned — Claude Code surfaces them
# to every contributor, so they live in the repo. Everything else under
# `.claude/` (per-session worktrees, transcripts) stays local-only.
.claude/*
!.claude/skills/
.claude/skills/*/state/

# GSD-style agent planning artifacts (not used in this repo; if an agent
# writes here, the contents belong in a Linear issue or .claude/ — not git)
.planning/

# Playwright
.auth
playwright-report
test-results
.playwright-mcp
apps/web/e2e/.results/

# Misc
.DS_Store
*.pem
