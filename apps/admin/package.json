{
  "name": "admin",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "generate:routes": "node scripts/generate-route-registry.mjs",
    "predev": "pnpm run generate:routes",
    "prebuild": "pnpm run generate:routes",
    "dev": "next dev --turbopack --port 3100",
    "build": "next build",
    "build:storybook": "cd ../../packages/ui && SB_FULL=1 pnpm exec storybook build -o ../../apps/admin/.storybook-static",
    "start": "next start",
