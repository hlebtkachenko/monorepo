{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:org-new": "eslint app/o --max-warnings 0",
    "lint:org-orphan": "eslint app lib e2e -c eslint.org-boundary.config.js --no-inline-config --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.63.0",
    "@tanstack/react-table": "^8.21.3",
    "@workspace/accounting": "workspace:*",
    "@workspace/auth": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/i18n": "workspace:*",
    "@workspace/notify": "workspace:*",
    "@workspace/org-provisioning": "workspace:*",
    "@workspace/shared": "workspace:*",
    "@workspace/storage": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "~1.6.11",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/testcontainers": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.5",
    "jsdom": "^29.1.1",
    "postgres": "^3.4.7",
    "size-limit": "^12.1.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "size-limit": [
    {
      "name": "Total JS (brotli)",
      "path": ".next/static/**/*.js",
      "limit": "3 MB",
      "running": false
    },
    {
      "name": "Total JS (raw)",
      "path": ".next/static/**/*.js",
      "limit": "12 MB",
      "brotli": false,
      "gzip": false,
      "running": false
    }
  ]
}
