{
  "name": "@afframe/mcp",
  "version": "0.0.1",
  "private": true,
  "description": "Official MCP server for the Afframe public API.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "afframe-mcp": "./bin/afframe-mcp.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen": "tsx scripts/gen-tools.ts"
  },
  "dependencies": {
    "@afframe/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
