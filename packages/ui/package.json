    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@workspace/eslint-config": "workspace:*",
