{
  "name": "monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "typecheck:watch": "turbo watch typecheck",
    "test": "turbo test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm turbo boundaries && pnpm exec spectral lint apps/api/openapi/v1.json --ruleset apps/api/.spectral.yaml",
    "knip": "knip",
    "check:brand-placeholders": "node scripts/check-brand-placeholders.mjs",
    "check:client-secrets": "node scripts/check-client-secrets.mjs",
    "check:nav": "tsx scripts/check-nav.ts",
    "check:sitemap": "tsx scripts/check-sitemap.ts",
    "check:structure": "tsx scripts/gen-structure.ts --check",
    "check:pr-title": "node scripts/check-pr-title.mjs",
    "gen:structure": "tsx scripts/gen-structure.ts",
    "gen:all": "tsx scripts/gen-all.ts",
    "prepare": "lefthook install --force || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@stoplight/spectral-cli": "^6.15.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.4.1",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.10.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  }
}
