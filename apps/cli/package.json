{
  "name": "@afframe/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Official command-line client for the Afframe public API.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "afframe": "./bin/afframe.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@afframe/sdk": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.205",
    "@workspace/brain": "workspace:*",
    "@workspace/intake": "workspace:*",
    "@workspace/registries": "workspace:*",
    "@workspace/shared": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
