# Template for apps/bot/.dev.vars (local Worker secrets, gitignored, chmod 600).
# Copy this file to .dev.vars and fill in real values.
#
# INGEST_SECRET: run `scripts/bot-dev-vars.sh` from the repo root instead of
# filling this in by hand — it fetches the shared NOTIFY_SHARED_SECRET value
# from SSM/Vault and writes the line for you. See docs/ENVIRONMENT-VARIABLES.md.

BOT_TOKEN=
TELEGRAM_USER_ID=
WEBHOOK_SECRET=
INGEST_SECRET=
