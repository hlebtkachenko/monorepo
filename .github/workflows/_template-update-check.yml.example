# Template for custom update-check workflows.
# Copy this file, remove the .example extension, and adapt for your dependency.
#
# Use this ONLY for things Dependabot cannot track:
#   - Source-copied code (shadcn, copy-pasted snippets with upstream)
#   - Non-registry tools (binaries installed via curl/wget)
#   - Internal version pins not in package.json
#
# Dependabot already handles: npm packages, GitHub Actions, Docker images.
# Do NOT create a custom workflow for those.

name: <name> update check

on:
  schedule:
    - cron: "0 9 * * 1"
  workflow_dispatch:

permissions:
  issues: write

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.1

      # --- ADAPT THIS SECTION ---
      - name: Check for updates
        id: check
        run: |
          # Compare current version vs latest available.
          # Set has_updates=true if update found.
          #
          # Example for a CLI tool:
          #   CURRENT=$(<tool> --version)
          #   LATEST=$(curl -s https://api.github.com/repos/<org>/<repo>/releases/latest | jq -r .tag_name)
          #
          # Example for source-copied code:
          #   OUTPUT=$(<tool> diff 2>&1 || true)
          #   if echo "$OUTPUT" | grep -qE "changes"; then ...
          #
          echo "has_updates=false" >> "$GITHUB_OUTPUT"
      # --- END ADAPT ---

      - name: Check for existing issue
        if: steps.check.outputs.has_updates == 'true'
        id: existing
        run: |
          # Use a unique label per dependency to avoid duplicate issues
          COUNT=$(gh issue list --label <dependency>-update --state open --json number --jq length)
          echo "exists=$COUNT" >> "$GITHUB_OUTPUT"
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Create issue
        if: steps.check.outputs.has_updates == 'true' && steps.existing.outputs.exists == '0'
        run: |
          gh issue create \
            --title "chore: <dependency> update available" \
            --label <dependency>-update \
            --body "New version of <dependency> detected. Review and update."
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
