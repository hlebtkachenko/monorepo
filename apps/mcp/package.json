{
  "name": "@afframe/mcp",
  "version": "0.0.1",
  "private": true,
  "description": "Official MCP server for the Afframe public API.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "afframe-mcp": "./bin/afframe-mcp.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen": "tsx scripts/gen-tools.ts",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production"
  },
  "dependencies": {
    "@afframe/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/node": "^26.0.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.105.0"
  }
}
