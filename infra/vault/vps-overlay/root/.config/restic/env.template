# Template for /root/.config/restic/.env on the Hostinger VPS.
#
# Copy this file to /root/.config/restic/.env, fill in the values, then
# `chmod 0600 /root/.config/restic/.env && chown root:root /root/.config/restic/.env`.
# NEVER commit a filled-in copy.
#
# Loaded by /usr/local/sbin/vault-backup. Required by the systemd unit
# /etc/systemd/system/vault-backup.service.
#
# Tracks: AFF-245 M2. Plan: docs/plans/SECRETS-MIGRATION.md § M2.

# ---- restic repo password (single secret, both repos) -------------------
#
# Generate once: `openssl rand -base64 32`
# Escrow: macOS Keychain entry `afframe-vault-restic-password` + paper at
# safe-deposit. Without this value, BOTH R2 and B2 repos are unreadable —
# restic encrypts client-side before upload, so cloud-side access alone is
# useless to an attacker AND to you if you lose it.
RESTIC_PASSWORD=<paste-32+byte-base64>

# ---- restic repository URLs --------------------------------------------
#
# R2 (primary): S3-compatible, region "auto", virtual-host-style URL.
# Bucket `afframe-vault-backup` in the EU region.
# Replace <accountid> with your Cloudflare account hex (right sidebar of any
# Cloudflare dashboard page).
RESTIC_REPOSITORY_PRIMARY=s3:https://<accountid>.eu.r2.cloudflarestorage.com/afframe-vault-backup

# B2 (secondary): native B2 path-style.
# Bucket `afframe-vault-backup-secondary` (any B2 region).
RESTIC_REPOSITORY_SECONDARY=b2:afframe-vault-backup-secondary:/

# ---- Cloudflare R2 token (S3-compatible API credentials) ----------------
#
# Provisioned at https://dash.cloudflare.com → R2 → Manage R2 API Tokens
#   - Permission: Object Read & Write
#   - Bucket scope: only `afframe-vault-backup`
#   - TTL: long-lived (rotate every 90 days, calendar)
# AWS_*-named because restic re-uses the standard S3 SDK env vars even when
# pointing at R2.
AWS_ACCESS_KEY_ID=<paste-r2-access-key-id>
AWS_SECRET_ACCESS_KEY=<paste-r2-secret>

# ---- Backblaze B2 app key ----------------------------------------------
#
# Provisioned at https://secure.backblaze.com → App Keys → Add Application Key
#   - Permission: Read + Write
#   - Bucket: only `afframe-vault-backup-secondary`
#   - Capabilities: keep default; restic needs read/write/list/delete on the bucket
# Rotate every 90 days alongside R2.
B2_ACCOUNT_ID=<paste-b2-key-id>
B2_ACCOUNT_KEY=<paste-b2-application-key>

# ---- Vault token for raft snapshot save --------------------------------
#
# Either the initial root token (interim — replace post M3) OR a dedicated
# token issued from a policy that allows ONLY `sys/storage/raft/snapshot`.
# Operator should mint the scoped token after M3 (Vault AWS auth) lands:
#
#     vault policy write backup - <<'EOF'
#     path "sys/storage/raft/snapshot" { capabilities = ["read"] }
#     EOF
#     vault token create -policy=backup -ttl=8760h -display-name=backup-job
#
# Until then, use the initial root token from M1 escrow.
VAULT_TOKEN=<paste-vault-backup-token>
