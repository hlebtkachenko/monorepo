{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open --quiet --disable-telemetry",
    "storybook:full": "SB_FULL=1 storybook dev -p 6006 --no-open --quiet --disable-telemetry",
    "build-storybook": "SB_FULL=1 storybook build",
    "test-storybook": "test-storybook",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:stories": "tsx scripts/audit-stories.ts",
    "audit:stories:fix": "tsx scripts/audit-stories.ts --fix",
    "check:icon-packs": "tsx scripts/check-icon-packs.ts",
    "check:shadcn-upstream": "tsx scripts/shadcn-upstream.ts check",
    "review:shadcn-upstream": "tsx scripts/shadcn-upstream.ts review"
  },
  "dependencies": {
