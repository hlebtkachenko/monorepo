  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": [
      "./src/lib/*.ts",
      "./src/lib/*.tsx"
    ],
    "./components/*": "./src/components/*/index.ts",
    "./blocks/*": "./src/blocks/*/index.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./brand-assets": "./src/brand-assets/index.ts",
    "./brand-assets/constants": "./src/brand-assets/constants.ts",
    "./brand-assets/tokens": "./src/brand-assets/tokens.ts",
    "./brand-assets/server": "./src/brand-assets/text-server.ts",
