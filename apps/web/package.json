{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.52.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@workspace/ui": "workspace:*",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "sonner": "^2.0.7",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3"
  },
  "size-limit": [
    {
      "name": "Per-chunk JS budget",
      "path": ".next/static/**/*.js",
      "limit": "600 KB"
    },
    {
      "name": "Total client bundle",
      "path": ".next/static/**/*.js",
      "limit": "2.5 MB",
      "brotli": false,
      "gzip": false
    }
  ]
}
