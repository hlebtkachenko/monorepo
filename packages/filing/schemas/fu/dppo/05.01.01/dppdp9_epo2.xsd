                        <xs:maxLength value="35"/>
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:attribute>
                  <xs:attribute name="psc_banky" use="optional">
                    <xs:simpleType>
                      <xs:restriction base="xs:string">
