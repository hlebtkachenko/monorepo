{
  "name": "@afframe/sdk",
  "version": "0.0.1",
  "private": true,
  "description": "Official TypeScript SDK for the Afframe public API (api.afframe.com/v1).",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./schemas": "./src/schemas.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen": "openapi-typescript ../../apps/api/openapi/v1.json -o ./src/generated/openapi.ts"
  },
  "dependencies": {
    "@workspace/shared": "workspace:*",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.4.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
