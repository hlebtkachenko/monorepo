[Unit]
Description=Vault → SSM sync timer — fires every 5 min
Documentation=https://github.com/hlebtkachenko/monorepo/blob/main/docs/runbooks/VAULT-OPS.md#adding-a-new-secret

[Timer]
OnBootSec=2min
OnUnitActiveSec=5min
Persistent=true
RandomizedDelaySec=30
Unit=vault-to-ssm-sync.service

[Install]
WantedBy=timers.target
