{
  "name": "@workspace/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./types": "./src/types.ts",
    "./columns": "./src/columns.ts",
    "./tenancy": "./src/tenancy.ts",
    "./policies": "./src/policies/rls.ts",
    "./audit": "./src/audit/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node -e \"console.error('drizzle-kit generate is forbidden in this repo. Migrations are handwritten SQL in packages/db/migrations/. See ADR-0009.'); process.exit(1)\"",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "db:push": "node -e \"console.error('drizzle-kit push is forbidden in this repo. Apply migrations via pnpm db:migrate. See ADR-0009.'); process.exit(1)\"",
    "db:studio": "drizzle-kit studio",
    "db:schema-snapshot": "bash ../../scripts/db-schema-snapshot.sh > schema-snapshot.sql",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@workspace/observability": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/testcontainers": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
