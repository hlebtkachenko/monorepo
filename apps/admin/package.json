    "@workspace/i18n": "workspace:*",
    "@workspace/notify": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "~1.6.11",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
