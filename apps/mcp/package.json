{
  "name": "@afframe/mcp",
  "version": "0.1.0",
  "description": "Official MCP server for the Afframe public API.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hlebtkachenko/monorepo.git",
    "directory": "apps/mcp"
  },
  "bin": {
    "afframe-mcp": "./bin/afframe-mcp.js"
  },
  "files": [
    "bin",
    "dist/server.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen": "tsx scripts/gen-tools.ts",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@afframe/sdk": "workspace:*",
    "@cloudflare/workers-types": "^5.20260706.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.0.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsup": "^8.5.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.105.0",
    "zod": "^4.4.3"
  }
}
