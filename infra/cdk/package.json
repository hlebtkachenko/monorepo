{
  "name": "@workspace/cdk",
  "private": true,
  "version": "0.0.1",
  "description": "AWS CDK v2 application stacks for the monorepo.",
  "bin": {
    "infra-cdk": "bin/app.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "AWS_ACCOUNT_ID=123456789012 APP_DOMAIN=test.example.com vitest run",
    "test:watch": "AWS_ACCOUNT_ID=123456789012 APP_DOMAIN=test.example.com vitest",
    "synth": "cdk synth --all",
    "diff": "cdk diff --all",
    "deploy": "cdk deploy --all --require-approval=never",
    "destroy": "cdk destroy --all",
    "bootstrap": "cdk bootstrap",
    "drift": "cdk drift --all"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "cdk-monitoring-constructs": "10.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-ecs": "^3.1053.0",
    "@aws-sdk/client-rds": "^3.1053.0",
    "@aws-sdk/client-sns": "^3.1048.0",
    "@types/node": "^25.9.1",
    "aws-cdk": "^2.1124.1",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.4.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
