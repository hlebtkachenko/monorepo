# apps/web — environment variables
#
# This file is the canonical reference for vars `apps/web` reads at runtime.
# Copy to `.env.local` for development, or run `bash scripts/generate-env.sh`
# from the repo root to materialize a `.env.local` with freshly generated
# secrets.
#
# In production, values come from AWS Secrets Manager + ECS task env (see
# `infra/cdk/lib/app-stack.ts` and `docs/runbooks/AWS-DEPLOY.md`).
#
# Cross-reference: `docs/env-vars.md` (full registry, including api/workers).

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
# Public hostname (no protocol). Used for cookie domain / link composition.
# Production: staging.afframe.com | app.afframe.com.
APP_DOMAIN=localhost
# Dev listen port. Optional; defaults to 3000. The auth base-URL resolver
# in `packages/auth/src/server.ts` rewrites BETTER_AUTH_URL's port to match
# this so multi-instance local dev still produces working magic links.
PORT=3000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# App runtime queries: pgBouncer transaction mode (port 6432), role app_user.
# FORCE RLS active on this connection.
DATABASE_URL=postgres://app_user:dev_user@localhost:6432/app_dev
# Migrations + worker queue: direct Postgres (port 5432), role app_owner.
# pg-boss + drizzle migrator reject port 6432.
DATABASE_DIRECT_URL=postgres://app_owner:dev_owner@localhost:5432/app_dev

# ---------------------------------------------------------------------------
# Better Auth (identity only)
# ---------------------------------------------------------------------------
# 32+ bytes. `openssl rand -base64 33`. NEVER commit. In prod this comes
# from Secrets Manager (`/monorepo/{env}/auth/better-auth-secret`).
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-33
# Absolute origin Better Auth uses for cookie scope, email links, trusted
# origin checks. In production this MUST match the public URL exactly.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Comma-separated list of origins allowed to call /api/auth/*. Add every
# host the client may reach the server from (apex + www, staging, etc.).
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# AI-tool token signing secret. Same generator as BETTER_AUTH_SECRET. Used by
# `packages/auth/src/tokens/*` to sign signup / invite / login-email JWTs.
APP_TOKEN_SECRET=replace-with-openssl-rand-base64-33

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
# Backend selection. Leave unset to auto-detect:
#   dev (NODE_ENV != production) -> console (logs to stdout + /api/dev/outbox)
#   prod with RESEND_API_KEY      -> Resend
#   prod with AWS_REGION          -> SES v2 (task IAM role grants ses:SendEmail)
# Force a backend with: EMAIL_TRANSPORT=console | resend | ses
# EMAIL_TRANSPORT=

# From address. Must be on a verified domain for Resend/SES.
EMAIL_FROM=no-reply@localhost

# Resend API key. Empty in dev (= console transport). Required if
# EMAIL_TRANSPORT=resend or for prod fallback with no AWS_REGION.
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# AWS (optional in dev; required wiring is set by infra/cdk in prod)
# ---------------------------------------------------------------------------
# AWS_REGION=eu-central-1
# APP_BUCKET=

# ---------------------------------------------------------------------------
# Observability (optional in dev)
# ---------------------------------------------------------------------------
# Empty = Sentry SDK noops. Set in prod via repo secret + task env.
# SENTRY_DSN=
