{
  "app": "npx tsx bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "node_modules"
    ]
  },
  "context": {
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,
    "@aws-cdk/aws-rds:databaseProxyUniqueResourceName": true,
    "@aws-cdk/aws-s3:serverAccessLogsUseBucketPolicy": true,
    "@aws-cdk/aws-lambda:recognizeVersionProps": true,
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true,
    "@aws-cdk/aws-ecs:reduceEc2FargateCloudWatchPermissions": true,
    "@aws-cdk/core:newStyleStackSynthesis": true,
    "homeRegion": "eu-central-1",
    "drRegion": "eu-west-1",
    "validEnvironments": ["staging", "production"],
    "_secret-arn-placeholders": "Synth/CI fallbacks for the 4 workflow-managed secrets. The deploy workflow ALWAYS overrides these with --context flags carrying the real captured ARNs (see _deploy-aws.yml's Deploy step). Account 000000000000 makes any leak loud in the template. Never deploy without the workflow's --context overrides.",
    "cloudflareTunnelSecretArn": "arn:aws:secretsmanager:eu-central-1:000000000000:secret:placeholder-cloudflare-tunnel-token-AAAAAA",
    "resendApiKeySecretArn": "arn:aws:secretsmanager:eu-central-1:000000000000:secret:placeholder-resend-api-key-BBBBBB",
    "betterAuthSecretArn": "arn:aws:secretsmanager:eu-central-1:000000000000:secret:placeholder-better-auth-secret-CCCCCC",
    "appTokenSecretArn": "arn:aws:secretsmanager:eu-central-1:000000000000:secret:placeholder-app-token-secret-DDDDDD"
  }
}
