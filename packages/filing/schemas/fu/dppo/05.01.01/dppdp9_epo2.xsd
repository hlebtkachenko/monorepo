                      </xs:restriction>
                    </xs:simpleType>
                  </xs:attribute>
                  <xs:attribute name="kc_rozv_min" use="optional">
                    <xs:annotation>
                      <xs:documentation>Hodnota ve sloupci stav k rozvahovému dni minulého účetního období (v tis.).</xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="xs:decimal">
                        <xs:totalDigits value="14"/>
                        <xs:fractionDigits value="0"/>
