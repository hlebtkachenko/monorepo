{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.56.0",
    "@workspace/auth": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/i18n": "workspace:*",
    "@workspace/notify": "workspace:*",
    "@workspace/shared": "workspace:*",
    "@workspace/storage": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "~1.6.11",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@workspace/auth": "workspace:*",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/testcontainers": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.4.0",
    "postgres": "^3.4.7",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "size-limit": [
    {
      "name": "Total JS (brotli)",
      "path": ".next/static/**/*.js",
      "limit": "1.5 MB",
      "running": false
    },
    {
      "name": "Total JS (raw)",
      "path": ".next/static/**/*.js",
      "limit": "5 MB",
      "brotli": false,
      "gzip": false,
      "running": false
    }
  ]
}
