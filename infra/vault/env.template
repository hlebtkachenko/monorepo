# Template for /srv/secrets/vault/.env on the Hostinger VPS.
#
# Copy this file to /srv/secrets/vault/.env, fill in the values, then
# `chmod 0600 /srv/secrets/vault/.env`. NEVER commit a filled-in copy.
#
# Tracks: AFF-245 M1 step 4. Plan: docs/plans/SECRETS-MIGRATION.md.

# ---- AWS KMS auto-unseal (vault container) -------------------------------
#
# Credentials for the IAM user `vault-unseal-vps` (created by the
# SecretsBootstrap CDK stack). Generate the keypair once with:
#
#     aws iam create-access-key --user-name vault-unseal-vps
#
# Store the output (both fields) in macOS Keychain + offline escrow per
# the irreversible-ops register, THEN paste them here. Rotate every 90 days.
#
# The variable names are namespaced with VAULT_KMS_ so a future second AWS
# integration (e.g. Vault AWS IAM auth method in M3) cannot collide.
VAULT_KMS_AWS_ACCESS_KEY_ID=<paste-AccessKeyId-from-aws-iam-create-access-key>
VAULT_KMS_AWS_SECRET_ACCESS_KEY=<paste-SecretAccessKey-from-aws-iam-create-access-key>

# ---- Cloudflare Tunnel (cloudflared sidecar) -----------------------------
#
# Token from the Cloudflare Zero Trust dashboard → Networks → Tunnels →
# create new tunnel `afframe-vault` → copy the token (single eyes-only step;
# never logged, never echoed). Tunnel public hostname:
#
#     secrets-admin.afframe.com  →  http://vault:8200
#
# Configured via the Cloudflare dashboard / API, not in this repo. Token
# rotation is non-disruptive (rotate via dashboard, paste new value here,
# `docker compose up -d cloudflared`).
CLOUDFLARE_TUNNEL_TOKEN=<paste-tunnel-token-from-cloudflare-zero-trust-dashboard>
