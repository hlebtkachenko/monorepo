{
  "extends": "@workspace/typescript-config/cloudflare-worker.json",
  "compilerOptions": {
    // src/ is vendored from AdiRishi/turborepo-remote-cache-cloudflare
    // (see SOURCE.md), written without noUncheckedIndexedAccess. Keep the
    // flag off here to stay byte-identical with upstream instead of
    // patching vendored source. Every non-vendored worker inherits the
    // flag from the preset.
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*.ts"]
}
