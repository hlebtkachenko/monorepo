{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "futureFlags": {
    "affectedUsingTaskInputs": true,
    "pruneIncludesGlobalFiles": true
  },
  "globalDependencies": ["tsconfig.json", "eslint.config.js", "pnpm-workspace.yaml", ".npmrc"],
  "globalEnv": ["CI", "NODE_ENV", "TESTCONTAINERS_REUSE_ENABLE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["BUILD_SHA", "BUILD_TIME", "BUILD_VERSION", "NODE_ENV"],
      "outputLogs": "new-only"
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"]
    },
    "format": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "env": ["AWS_ACCOUNT_ID", "APP_DOMAIN"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": ["coverage/**"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": ["storybook-static/**"]
    },
    "test-storybook": {
      "dependsOn": ["build-storybook"],
      "cache": false
    },
    "size": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "synth": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": ["cdk.out/**"],
      "env": ["AWS_ACCOUNT_ID", "APP_DOMAIN"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interruptible": true
    }
  }
}
