{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open --quiet --disable-telemetry",
    "storybook:full": "SB_FULL=1 storybook dev -p 6006 --no-open --quiet --disable-telemetry",
    "build-storybook": "SB_FULL=1 storybook build",
    "test-storybook": "test-storybook",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:stories": "tsx scripts/audit-stories.ts",
    "audit:stories:fix": "tsx scripts/audit-stories.ts --fix"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@base-ui/react": "^1.4.1",
    "@diceui/mention": "^0.8.0",
    "@diceui/tags-input": "^0.7.2",
    "@floating-ui/react-dom": "^2.1.8",
    "@hugeicons/core-free-icons": "^4.1.2",
    "@hugeicons/react": "^1.1.6",
    "@paper-design/shaders": "^0.0.76",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@workspace/shared": "workspace:*",
    "border-beam": "^1.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.5",
    "react-easy-crop": "^5.5.7",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@turbo/gen": "^2.9.8",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "axe-playwright": "^2.2.2",
    "chromatic": "^16.9.1",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "postcss-load-config": "^6.0.1",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": [
      "./src/lib/*.ts",
      "./src/lib/*.tsx"
    ],
    "./components/*": "./src/components/*/index.ts",
    "./blocks/*": "./src/blocks/*/index.ts",
    "./hooks/*": "./src/hooks/*.ts"
  }
}
