; userlist.txt — pgBouncer credential file.
;
; NEVER commit the real userlist.txt (it contains password hashes).
; Copy this file to userlist.txt and fill in the actual md5 hashes.
;
; auth_type = md5 (set in pgbouncer.ini). Hash format:
;   "md5" + md5hex(password + username)
;
; Pre-computed hashes for the dev credentials defined in init.d/00-roles.sql:
;   app_user  / dev_user  → md5("dev_userapp_user")
;   app_owner / dev_owner → md5("dev_ownerapp_owner")
;
; To recompute:
;   python3 -c "import hashlib; print('md5' + hashlib.md5(b'dev_userapp_user').hexdigest())"
;
; The userlist.txt file is listed in .gitignore.

"app_user"   "md5152fe51b24e80b8200afbc894c4206c8"
"app_owner"  "md5917573551e6202a8927cc4eb6c51f04e"
