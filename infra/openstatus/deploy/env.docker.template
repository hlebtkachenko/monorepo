# OpenStatus stack env template — rendered by .github/workflows/deploy-statuspage.yml
# via `envsubst` into the file uploaded to the VPS as `/opt/openstatus/.env.docker`.
#
# Filename intentionally lacks a leading dot so the template is not mistaken
# for a real env file by editor / scanner tooling. The rendered output on the
# VPS is `.env.docker` (chmod 600).
#
# Five placeholders pull from GitHub Actions secrets at deploy time:
#   OPENSTATUS_AUTH_SECRET, OPENSTATUS_RESEND_API_KEY, OPENSTATUS_TUNNEL_TOKEN,
#   OPENSTATUS_PROBE_KEY, OPENSTATUS_DB_AUTH_TOKEN.
# Everything else is literal config.
#
# Why the empty/placeholder values: the OpenStatus Bun binaries load every
# integration's SDK at startup (e.g. `@upstash/redis`, `@upstash/qstash`,
# `@vercel/blob`), and the SDK constructors throw if their env var is *missing*
# even when the feature is unused. They tolerate empty strings or local
# placeholders — but not absent keys. The upstream `.env.docker.example` is
# therefore the minimum surface we have to render, not the maximum.
#
# See infra/openstatus/deploy/README.md for one-time setup + rotation.

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=http://libsql:8080
DATABASE_AUTH_TOKEN=${OPENSTATUS_DB_AUTH_TOKEN}

# ============================================================================
# Redis & queue — required by @upstash/redis at startup; values can be local
# placeholders since we do not use Upstash on self-host.
# ============================================================================
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=placeholder
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_TOKEN=
QSTASH_URL=https://qstash.upstash.io/v1/publish/

# ============================================================================
# Analytics
# ============================================================================
TINY_BIRD_API_KEY=
TINYBIRD_URL=http://tinybird-local:7181

# ============================================================================
# Email — Resend (REQUIRED for magic-link login + status-subscriber confirms)
# ============================================================================
RESEND_API_KEY=${OPENSTATUS_RESEND_API_KEY}

# ============================================================================
# Authentication
# ============================================================================
AUTH_SECRET=${OPENSTATUS_AUTH_SECRET}
AUTH_URL=https://monitoring.afframe.com
AUTH_TRUST_HOST=true
SELF_HOST="true"
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ============================================================================
# Google Cloud (optional integrations — upstream defaults)
# ============================================================================
GCP_PROJECT_ID=your-value
GCP_LOCATION=your-value
GCP_CLIENT_EMAIL=your-value
GCP_PRIVATE_KEY=your-value

# ============================================================================
# Cron / API key management
# ============================================================================
CRON_SECRET=your-random-cron-secret
UNKEY_API_ID=
UNKEY_TOKEN=
SUPER_ADMIN_TOKEN=
FLY_REGION=self-hosted

# ============================================================================
# Stripe / Vercel / Sentry / OpenPanel / PagerDuty / Slack / Telegram
# (upstream-required env, never used on self-host — empty is fine)
# ============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PROJECT_ID_VERCEL=
TEAM_ID_VERCEL=
VERCEL_AUTH_BEARER_TOKEN=
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
PAGERDUTY_APP_ID=
SLACK_SUPPORT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# ============================================================================
# Service config
# ============================================================================
NODE_ENV=production
NEXT_PUBLIC_URL=https://monitoring.afframe.com
SCREENSHOT_SERVICE_URL=
OPENSTATUS_INGEST_URL=http://workflows:3000
TURBO_ENV_MODE=loose
PLAYGROUND_UNKEY_API_KEY=
WORKSPACES_LOOKBACK_30=
WORKSPACES_HIDE_URL=

# ============================================================================
# Private-location probe
# ============================================================================
OPENSTATUS_KEY=${OPENSTATUS_PROBE_KEY}

# ============================================================================
# Cloudflare Tunnel connector
# ============================================================================
TUNNEL_TOKEN=${OPENSTATUS_TUNNEL_TOKEN}
